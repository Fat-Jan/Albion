# KOOK 机器人 Token（必填，从 KOOK 开发者后台获取，不要提交到 git）
KOOK_TOKEN_EU=
KOOK_TOKEN_ASIA=

# 区服配置（保持 gameinfo / AODP / AlbionBB / killboard 同区）
GAMEINFO_BASE_EU=https://gameinfo-ams.albiononline.com/api/gameinfo
AODP_BASE_EU=https://europe.albion-online-data.com
ALBIONBB_BASE_EU=https://api.albionbb.com/eu
ALBIONBB_WEB_BASE_EU=https://europe.albionbb.com
KILLBOARD_SERVER_EU=live_ams

GAMEINFO_BASE_ASIA=https://gameinfo-sgp.albiononline.com/api/gameinfo
AODP_BASE_ASIA=https://east.albion-online-data.com
ALBIONBB_BASE_ASIA=https://api.albionbb.com/asia
ALBIONBB_WEB_BASE_ASIA=https://east.albionbb.com
KILLBOARD_SERVER_ASIA=live_sgp

# 显示时间和自动战报窗口（默认北京时间 14:30 到次日 05:00）
DISPLAY_TZ_EU=Asia/Shanghai
DISPLAY_TZ_LABEL_EU=北京时间
DISPLAY_TZ_SHORT_LABEL_EU=北京
DISPLAY_TZ_ASIA=Asia/Shanghai
DISPLAY_TZ_LABEL_ASIA=北京时间
DISPLAY_TZ_SHORT_LABEL_ASIA=北京
BATTLE_REPORT_WINDOW_START=14:30
BATTLE_REPORT_WINDOW_END=05:00

# @机器人 自然语言入口显示名别名，多个用英文逗号分隔
KOOK_BOT_MENTION_ALIASES=

# 只读健康/API 端口与公开页面配置（可选）
HEALTH_PORT=
WEB_PUBLIC_BASE_URL=
KOOK_INVITE_URL_EU=
KOOK_INVITE_URL_ASIA=

# SQLite 路径
DB_PATH=data/bot.db

# 日志级别
LOG_LEVEL=INFO

# AI 辅助（LongCat/OpenAI 兼容；可选）
AI_ENABLED=false
AI_BASE_URL=https://api.longcat.chat/openai
AI_MODEL=LongCat-2.0-Preview
AI_API_KEY=
LONGCAT_API_KEY=
AI_TIMEOUT_SEC=20
AI_MAX_OUTPUT_TOKENS=800
